CompileFlags:
  Add:
    - -std=c11
    - -xc
    - -D__STDC_HOSTED__=0
    - -Wall
    - -Wextra
    - -Wno-unused-parameter
    - -Wno-unused-function
    - -Icommon/include

---
If:
  PathMatch: vellum/.*
CompileFlags:
  CompilationDatabase: build/vellum
  Add:
    - --target=i686-elf
    - -isystem /opt/homebrew/Cellar/i686-elf-gcc/15.2.0/lib/gcc/i686-elf/15.2.0/include
